---
import Header from '../components/Header.astro';
import '../styles/global.css';
import { siteMeta } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  image = '/favicon.svg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, siteMeta.siteUrl);
const pageTitle = title === siteMeta.title ? title : `${title} | ${siteMeta.siteName}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteMeta.siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, siteMeta.siteUrl)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="zh_CN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="keywords" content={siteMeta.keywords} />
    <meta name="author" content={siteMeta.author} />
    <meta name="theme-color" content={siteMeta.themeColor} />
  </head>
  <body>
    <Header />
    <slot />
    <footer class="site-footer">
      <div class="container footer-grid">
        <p>50 Apps Progress · {siteMeta.author}</p>
        <div class="footer-links">
          <a href={siteMeta.github} target="_blank" rel="noreferrer">GitHub</a>
          <a href={siteMeta.gitee} target="_blank" rel="noreferrer">Gitee</a>
          <a href="/wishlist">提交想法</a>
        </div>
      </div>
    </footer>
  </body>
</html>
