---
import ArchitectureDiagrams from '../ArchitectureDiagrams.astro';
import DiagramCallout from './primitives/DiagramCallout.astro';
import DiagramDefs from './primitives/DiagramDefs.astro';
import DiagramLane from './primitives/DiagramLane.astro';
import DiagramNode from './primitives/DiagramNode.astro';

const defsId = 'life';
const boot = [
  { x: 32, t: 'App 启动' },
  { x: 178, t: 'init appId' },
  { x: 314, t: 'channelCode' },
  { x: 468, t: 'deviceId' },
  { x: 612, t: 'device-login' },
  { x: 758, t: 'app-config' },
  { x: 904, t: '业务页面' },
];
---

<ArchitectureDiagrams
  id="diagram-lifecycle"
  title="图 5 · App 启动与支付主流程"
  caption="从冷启动到业务动作的典型路径：鉴权 → 拉配置 → 三分支（业务 / 文件 / 支付）→ 回调履约链。"
  highlights={['启动七步', '三分支', '支付回调链']}
>
  <svg viewBox="0 0 1100 520" role="img" aria-label="App 启动与支付主流程架构图">
    <DiagramDefs id={defsId} />
    <rect width="1100" height="520" fill={`url(#${defsId}-grid)`}></rect>

    <DiagramLane x={16} y={24} w={1068} h={88} label="启动链（鉴权 + 配置）" color="#dcecff" />

    {
      boot.map((n, i, arr) => (
        <>
          <DiagramNode
            x={n.x}
            y={44}
            w={128}
            h={44}
            title={n.t}
            variant={i >= 5 ? 'blue' : 'default'}
            defsId={defsId}
            rx={8}
          />
          {i < arr.length - 1 && (
            <line
              x1={n.x + 128}
              y1="66"
              x2={arr[i + 1].x}
              y2="66"
              stroke="#111"
              stroke-width="2"
              marker-end={`url(#${defsId}-arrow)`}
            />
          )}
        </>
      ))
    }

    <text x={612} y={38} font-size="9" fill="#5d625f">或 wechat-login</text>
    <text x={758} y={38} font-size="9" fill="#5d625f">effective-config</text>

    <line x1="968" y1="88" x2="968" y2="128" stroke="#111" stroke-width="2"></line>
    <polygon points="968,128 948,158 988,158" fill="#111"></polygon>

    <DiagramLane x={16} y={168} w={1068} h={148} label="业务动作三分支" color="#f7f3ea" />

    <g filter={`url(#${defsId}-shadow)`}>
      <rect
        x={32}
        y={204}
        width={320}
        height={96}
        rx="12"
        fill="#dff4e6"
        stroke="#111"
        stroke-width="2"></rect>
      <text x={52} y={232} font-size="13" font-weight="700" fill="#111">普通业务</text>
      <text x={52} y={254} font-size="11" fill="#5d625f">{'/app/{appId}/v1/*'}</text>
      <text x={52} y={274} font-size="11" fill="#5d625f">→ public-api → 业务 RPC + 共享 RPC</text>
      <text x={52} y={292} font-size="10" fill="#1f8f5f"
        >content · legal · feedback · notification</text
      >
    </g>

    <g filter={`url(#${defsId}-shadow)`}>
      <rect
        x={390}
        y={204}
        width={300}
        height={96}
        rx="12"
        fill="#ffe1dc"
        stroke="#111"
        stroke-width="2"></rect>
      <text x={410} y={232} font-size="13" font-weight="700" fill="#111">文件上传</text>
      <text x={410} y={254} font-size="11" fill="#5d625f">/v1/storage/*</text>
      <text x={410} y={274} font-size="11" fill="#5d625f">→ storage-api → file-rpc</text>
      <text x={410} y={292} font-size="10" fill="#5d625f">策略与元数据事实源在 file-rpc</text>
    </g>

    <g filter={`url(#${defsId}-shadow)`}>
      <rect
        x={728}
        y={204}
        width={340}
        height={96}
        rx="12"
        fill="#fff0c2"
        stroke="#111"
        stroke-width="2"></rect>
      <text x={748} y={232} font-size="13" font-weight="700" fill="#111">发起支付</text>
      <text x={748} y={254} font-size="11" fill="#5d625f">{'/app/{appId}/v1/payment/*'}</text>
      <text x={748} y={274} font-size="11" fill="#5d625f"
        >→ payment-rpc 创建订单 · IAP / 微信 / 支付宝</text
      >
      <text x={748} y={292} font-size="10" fill="#5d625f">客户端验单 + 服务端回调双通道</text>
    </g>

    <line
      x1="968"
      y1="158"
      x2="192"
      y2="204"
      stroke="#111"
      stroke-width="1.6"
      marker-end={`url(#${defsId}-arrow)`}></line>
    <line
      x1="968"
      y1="158"
      x2="540"
      y2="204"
      stroke="#111"
      stroke-width="1.6"
      marker-end={`url(#${defsId}-arrow)`}></line>
    <line
      x1="968"
      y1="158"
      x2="898"
      y2="204"
      stroke="#111"
      stroke-width="1.6"
      marker-end={`url(#${defsId}-arrow)`}></line>

    <DiagramLane x={16} y={332} w={1068} h={168} label="支付回调履约链" color="#fff0c2" />

    {
      [
        { x: 48, t: '支付回调', sub: '/v1/payment/callback' },
        { x: 228, t: 'payment-rpc', sub: '验单 · 更新订单' },
        { x: 408, t: 'vip-rpc', sub: '发放权益' },
        { x: 588, t: 'promotion-rpc', sub: '记录转化' },
        { x: 788, t: 'App 刷新', sub: '会员状态 UI' },
      ].map((n, i, arr) => (
        <>
          <DiagramNode
            x={n.x}
            y={372}
            w={158}
            h={54}
            title={n.t}
            subtitle={n.sub}
            variant={i === 1 ? 'blue' : i === 2 ? 'accent' : 'default'}
            defsId={defsId}
          />
          {i < arr.length - 1 && (
            <line
              x1={n.x + 158}
              y1="399"
              x2={arr[i + 1].x}
              y2="399"
              stroke="#111"
              stroke-width="2"
              marker-end={`url(#${defsId}-arrow)`}
            />
          )}
        </>
      ))
    }

    <DiagramCallout
      x={16}
      y={448}
      w={1068}
      title="记住"
      tone="tip"
      defsId={defsId}
      lines={[
        '支付回调走平台共享路径，不走 App 私有路由 · 页面显示会员态以 vip-rpc 为准 · 推广归因在 promotion-rpc',
      ]}
    />
  </svg>
</ArchitectureDiagrams>
