---
type Variant = 'default' | 'accent' | 'blue' | 'rpc' | 'storage' | 'admin' | 'muted';

interface Props {
  x: number;
  y: number;
  w?: number;
  h?: number;
  title: string;
  subtitle?: string;
  variant?: Variant;
  badge?: string;
  defsId?: string;
  rx?: number;
}

const {
  x,
  y,
  w = 118,
  h = 58,
  title,
  subtitle,
  variant = 'default',
  badge,
  defsId = 'd',
  rx = 10,
} = Astro.props;

const fills: Record<Variant, string> = {
  default: '#fffdf8',
  accent: `url(#${defsId}-grad-green)`,
  blue: `url(#${defsId}-grad-blue)`,
  rpc: '#e7e3db',
  storage: '#ffe1dc',
  admin: '#fff0c2',
  muted: '#f0eadf',
};

const titleFill = variant === 'accent' || variant === 'blue' ? '#fff' : '#111';
const subFill = variant === 'accent' ? '#dff4e6' : variant === 'blue' ? '#dcecff' : '#5d625f';
---

<g filter={`url(#${defsId}-shadow)`}>
  <rect
    x={x}
    y={y}
    width={w}
    height={h}
    rx={rx}
    fill={fills[variant]}
    stroke="#111"
    stroke-width="2"></rect>
  {
    badge && (
      <>
        <rect x={x + w - 52} y={y - 10} width="48" height="18" rx="9" fill="#111" />
        <text
          x={x + w - 28}
          y={y + 3}
          text-anchor="middle"
          font-size="9"
          font-weight="700"
          fill="#fff"
        >
          {badge}
        </text>
      </>
    )
  }
  <text
    x={x + w / 2}
    y={subtitle ? y + 24 : y + h / 2 + 5}
    text-anchor="middle"
    font-size="13"
    font-weight="700"
    fill={titleFill}
  >
    {title}
  </text>
  {
    subtitle && (
      <text x={x + w / 2} y={y + 42} text-anchor="middle" font-size="10" fill={subFill}>
        {subtitle}
      </text>
    )
  }
</g>
