---
interface Props {
  x: number;
  y: number;
  w: number;
  h: number;
  label: string;
  color?: string;
}

const { x, y, w, h, label, color = '#f0eadf' } = Astro.props;
---

<g>
  <rect
    x={x}
    y={y}
    width={w}
    height={h}
    rx="12"
    fill={color}
    stroke="#111"
    stroke-width="1.5"
    opacity="0.55"></rect>
  <text x={x + 14} y={y + 22} font-size="11" font-weight="700" fill="#111" opacity="0.85">
    {label}
  </text>
</g>
