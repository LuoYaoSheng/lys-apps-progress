---
interface Props {
  x: number;
  y: number;
  w: number;
  title: string;
  lines: string[];
  tone?: 'neutral' | 'warn' | 'tip';
  defsId?: string;
}

const { x, y, w, title, lines, tone = 'neutral', defsId = 'd' } = Astro.props;
const fills = { neutral: '#f7f3ea', warn: '#fff0c2', tip: '#dff4e6' };
const h = 36 + lines.length * 18;
---

<g filter={`url(#${defsId}-shadow)`}>
  <rect x={x} y={y} width={w} height={h} rx="10" fill={fills[tone]} stroke="#111" stroke-width="1.8"
  ></rect>
  <text x={x + 16} y={y + 24} font-size="12" font-weight="700" fill="#111">{title}</text>
  {
    lines.map((line, i) => (
      <text x={x + 16} y={y + 44 + i * 18} font-size="11" fill="#5d625f">
        {line}
      </text>
    ))
  }
</g>
