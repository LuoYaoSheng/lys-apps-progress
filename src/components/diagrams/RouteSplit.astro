---
import ArchitectureDiagrams from '../ArchitectureDiagrams.astro';
---

<ArchitectureDiagrams
  id="diagram-routes"
  title="图 3 · APISIX 路由分流"
  caption="对 App 只有一个认知：所有正式请求先进入 APISIX，再按路径前缀分流到不同门面。"
>
  <svg viewBox="0 0 900 380" role="img" aria-label="APISIX 路由分流架构图">
    <defs>
      <marker id="arr3" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill="#111"></path>
      </marker>
    </defs>
    <rect
      x="340"
      y="20"
      width="220"
      height="64"
      rx="10"
      fill="#1f8f5f"
      stroke="#111"
      stroke-width="2.5"></rect>
    <text x="450" y="48" text-anchor="middle" font-size="16" font-weight="700" fill="#fff"
      >APISIX</text
    >
    <text x="450" y="68" text-anchor="middle" font-size="11" fill="#dff4e6">唯一公网入口</text>

    <line x1="450" y1="84" x2="450" y2="120" stroke="#111" stroke-width="2"></line>
    <line x1="120" y1="120" x2="780" y2="120" stroke="#111" stroke-width="2"></line>

    {
      [
        {
          x: 40,
          path: '/app/{appId}/v1/*',
          desc: 'App 业务 API',
          target: 'public-api',
          color: '#dcecff',
        },
        {
          x: 240,
          path: '/v1/{domain}/*',
          desc: '平台共享 API',
          target: 'auth/payment/...',
          color: '#dff4e6',
        },
        {
          x: 440,
          path: '/v1/storage/*',
          desc: '文件上传',
          target: 'storage-api',
          color: '#ffe1dc',
        },
        {
          x: 640,
          path: '/admin-api/*',
          desc: '管理后台',
          target: 'admin-api',
          color: '#fff0c2',
        },
      ].map((r) => (
        <>
          <line
            x1={r.x + 90}
            y1="120"
            x2={r.x + 90}
            y2="150"
            stroke="#111"
            stroke-width="2"
            marker-end="url(#arr3)"
          />
          <rect
            x={r.x}
            y="155"
            width="180"
            height="100"
            rx="8"
            fill={r.color}
            stroke="#111"
            stroke-width="2"
          />
          <text
            x={r.x + 90}
            y="182"
            text-anchor="middle"
            font-size="11"
            font-weight="700"
            fill="#111"
          >
            {r.path}
          </text>
          <text x={r.x + 90} y="202" text-anchor="middle" font-size="11" fill="#5d625f">
            {r.desc}
          </text>
          <text
            x={r.x + 90}
            y="238"
            text-anchor="middle"
            font-size="12"
            font-weight="600"
            fill="#111"
          >
            → {r.target}
          </text>
        </>
      ))
    }

    <rect
      x="60"
      y="290"
      width="780"
      height="72"
      rx="8"
      fill="#fffdf8"
      stroke="#111"
      stroke-width="1.5"></rect>
    <text x="80" y="318" font-size="12" font-weight="700" fill="#111">命名约定</text>
    <text x="80" y="340" font-size="11" fill="#5d625f">
      appKey = 目录名（kebab-case） · appId = 去连字符 · 例：baby-diary → babydiary
    </text>
  </svg>
</ArchitectureDiagrams>
