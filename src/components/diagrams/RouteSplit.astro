---
import ArchitectureDiagrams from '../ArchitectureDiagrams.astro';
import DiagramCallout from './primitives/DiagramCallout.astro';
import DiagramDefs from './primitives/DiagramDefs.astro';
import DiagramNode from './primitives/DiagramNode.astro';

const defsId = 'route';
const routes = [
  {
    x: 32,
    path: '/app/{appId}/v1/*',
    desc: 'App 专属业务 API',
    example: 'babydiary/v1/records',
    target: 'gateway → public-api',
    color: '#dcecff',
    w: 240,
  },
  {
    x: 292,
    path: '/v1/{domain}/*',
    desc: '平台共享客户端入口',
    example: 'auth · payment · config',
    target: 'gateway → 共享 RPC',
    color: '#dff4e6',
    w: 240,
  },
  {
    x: 552,
    path: '/v1/storage/*',
    desc: '文件上传与访问',
    example: 'multipart · presign',
    target: 'storage-api → file-rpc',
    color: '#ffe1dc',
    w: 240,
  },
  {
    x: 812,
    path: '/admin-api/*',
    desc: '运营管理后台',
    example: 'RBAC · 配置写入',
    target: 'admin-api → config-rpc',
    color: '#fff0c2',
    w: 240,
  },
];
---

<ArchitectureDiagrams
  id="diagram-routes"
  title="图 3 · APISIX 路由分流"
  caption="对 App 只有一个认知：所有正式请求先进入 APISIX，再按路径前缀分流到不同门面与服务群。"
  highlights={['四路前缀', 'appId 命名', '门面分流']}
>
  <svg viewBox="0 0 1100 460" role="img" aria-label="APISIX 路由分流架构图">
    <DiagramDefs id={defsId} />
    <rect width="1100" height="460" fill={`url(#${defsId}-grid)`}></rect>

    <DiagramNode
      x={430}
      y={28}
      w={240}
      h={72}
      title="APISIX"
      subtitle="api.i2kai.com · 唯一公网入口"
      variant="accent"
      badge="L0"
      defsId={defsId}
    />

    <line x1="550" y1="100" x2="550" y2="132" stroke="#111" stroke-width="2.5"></line>
    <line x1="152" y1="132" x2="948" y2="132" stroke="#111" stroke-width="2.5"></line>

    {
      routes.map((r) => (
        <>
          <line
            x1={r.x + r.w / 2}
            y1="132"
            x2={r.x + r.w / 2}
            y2="158"
            stroke="#111"
            stroke-width="2.2"
            marker-end={`url(#${defsId}-arrow)`}
          />
          <g filter={`url(#${defsId}-shadow)`}>
            <rect
              x={r.x}
              y="162"
              width={r.w}
              height="148"
              rx="12"
              fill={r.color}
              stroke="#111"
              stroke-width="2"
            />
            <text
              x={r.x + r.w / 2}
              y="192"
              text-anchor="middle"
              font-size="12"
              font-weight="700"
              fill="#111"
            >
              {r.path}
            </text>
            <text x={r.x + r.w / 2} y="214" text-anchor="middle" font-size="11" fill="#5d625f">
              {r.desc}
            </text>
            <rect
              x={r.x + 16}
              y="228"
              width={r.w - 32}
              height="26"
              rx="6"
              fill="#fffdf8"
              stroke="#111"
              stroke-width="1"
            />
            <text x={r.x + r.w / 2} y="246" text-anchor="middle" font-size="10" fill="#5d625f">
              例：{r.example}
            </text>
            <text
              x={r.x + r.w / 2}
              y="288"
              text-anchor="middle"
              font-size="12"
              font-weight="700"
              fill="#111"
            >
              → {r.target}
            </text>
          </g>
        </>
      ))
    }

    <DiagramCallout
      x={32}
      y={340}
      w={520}
      title="命名约定"
      tone="neutral"
      defsId={defsId}
      lines={[
        'appKey = apps/ 目录名（kebab-case）',
        'appId = 去连字符（baby-diary → babydiary）',
        'public-api 路由前缀 /app/{appId}/v1/*',
      ]}
    />

    <DiagramCallout
      x={568}
      y={340}
      w={500}
      title="第三方回调"
      tone="tip"
      defsId={defsId}
      lines={[
        '微信支付 / 支付宝回调 → /v1/payment/*',
        '推广短链 · 广告 postback → /v1/* 或 /s/*',
        '不走 App 私有 /app/{appId} 路由',
      ]}
    />
  </svg>
</ArchitectureDiagrams>
