---
import ArchitectureDiagrams from '../ArchitectureDiagrams.astro';
import DiagramCallout from './primitives/DiagramCallout.astro';
import DiagramDefs from './primitives/DiagramDefs.astro';
import DiagramLane from './primitives/DiagramLane.astro';
import DiagramNode from './primitives/DiagramNode.astro';

const defsId = 'admin';
const chain = [
  { x: 24, title: '运营/管理员', sub: '浏览器', variant: 'default' as const },
  { x: 168, title: 'admin-web', sub: '五层菜单 UI', variant: 'admin' as const },
  { x: 312, title: 'APISIX', sub: 'admin.i2kai.com', variant: 'accent' as const },
  { x: 456, title: 'admin-api', sub: 'REST 门面', variant: 'default' as const },
  { x: 600, title: 'config-rpc', sub: '配置事实源', variant: 'blue' as const, badge: 'SSOT' },
  { x: 744, title: 'PostgreSQL', sub: 'sys_config', variant: 'muted' as const },
  { x: 888, title: 'ETCD', sub: '运行态快照', variant: 'muted' as const },
];

const consumers = ['gateway', 'payment-rpc', 'storage-api', 'auth-rpc', 'voice-rpc', 'vip-rpc'];
const adminLayers = ['工作台', '应用中心', '能力中心', '运营配置', '通用设置'];
---

<ArchitectureDiagrams
  id="diagram-admin"
  title="图 4 · Admin 控制面与配置生效"
  caption="页面保存成功 ≠ 运行态已生效。配置经 config-rpc 写入数据库与 ETCD，由 owner service 消费后才真正生效。"
  highlights={['控制面分离', 'config-rpc 事实源', 'ETCD 运行态']}
>
  <svg viewBox="0 0 1100 440" role="img" aria-label="Admin 控制面配置生效架构图">
    <DiagramDefs id={defsId} />
    <rect width="1100" height="440" fill={`url(#${defsId}-grid)`}></rect>

    <DiagramLane
      x={16}
      y={24}
      w={1068}
      h={118}
      label="控制面写入链路（Admin → 持久化）"
      color="#fff0c2"
    />

    {
      chain.map((n, i, arr) => (
        <>
          <DiagramNode
            x={n.x}
            y={52}
            w={128}
            h={62}
            title={n.title}
            subtitle={n.sub}
            variant={n.variant}
            badge={n.badge}
            defsId={defsId}
          />
          {i < arr.length - 1 && (
            <>
              <line
                x1={n.x + 128}
                y1="83"
                x2={arr[i + 1].x}
                y2="83"
                stroke="#111"
                stroke-width="2.2"
                marker-end={`url(#${defsId}-arrow)`}
              />
              <text
                x={(n.x + 128 + arr[i + 1].x) / 2}
                y="74"
                text-anchor="middle"
                font-size="9"
                fill="#5d625f"
              >
                {i === 3 ? 'REST' : i === 4 ? '写入' : ''}
              </text>
            </>
          )}
        </>
      ))
    }

    <line
      x1="952"
      y1="114"
      x2="952"
      y2="168"
      stroke="#1f8f5f"
      stroke-width="2.5"
      marker-end={`url(#${defsId}-arrow-green)`}></line>
    <text x="964" y="148" font-size="10" font-weight="600" fill="#1f8f5f">watch / pull</text>

    <DiagramLane
      x={16}
      y={168}
      w={1068}
      h={120}
      label="运行态消费（owner service 读取 ETCD 后生效）"
      color="#dff4e6"
    />

    {
      consumers.map((name, i) => (
        <DiagramNode
          x={32 + i * 172}
          y={204}
          w={152}
          h={48}
          title={name}
          variant="rpc"
          defsId={defsId}
          rx={8}
        />
      ))
    }

    <DiagramCallout
      x={16}
      y={308}
      w={340}
      title="Admin 五层菜单"
      tone="neutral"
      defsId={defsId}
      lines={adminLayers.map((l, i) => `${i + 1}. ${l}`)}
    />

    <DiagramCallout
      x={372}
      y={308}
      w={712}
      title="生效判断三问"
      tone="warn"
      defsId={defsId}
      lines={[
        '① admin-api 写库成功了吗？（持久化）',
        '② config-rpc 推送到 ETCD 了吗？（运行态快照）',
        '③ owner service 是否已 reload / watch 到新配置？（真正生效）',
      ]}
    />
  </svg>
</ArchitectureDiagrams>
