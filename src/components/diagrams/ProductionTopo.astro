---
import ArchitectureDiagrams from '../ArchitectureDiagrams.astro';
import DiagramCallout from './primitives/DiagramCallout.astro';
import DiagramDefs from './primitives/DiagramDefs.astro';
import DiagramLane from './primitives/DiagramLane.astro';
import DiagramNode from './primitives/DiagramNode.astro';

const defsId = 'prod';
---

<ArchitectureDiagrams
  id="diagram-production"
  title="图 6 · 生产部署拓扑"
  caption="公网经 Cloudflare 到香港业务机 APISIX；平台机负责 CI/CD 构建推送；开源进度站独立托管在 GitHub Pages。"
  highlights={['香港主运行面', '平台机 CI/CD', '入口收敛']}
>
  <svg viewBox="0 0 1100 540" role="img" aria-label="生产部署拓扑架构图">
    <DiagramDefs id={defsId} />
    <rect width="1100" height="540" fill={`url(#${defsId}-grid)`}></rect>

    <DiagramLane
      x={16}
      y={24}
      w={1068}
      h={148}
      label="生产公网链路（用户 → 运行时）"
      color="#dcecff"
    />

    <DiagramNode x={32} y={56} w={96} h={52} title="用户" subtitle="App / H5" defsId={defsId} />
    <line
      x1="128"
      y1="82"
      x2="168"
      y2="82"
      stroke="#111"
      stroke-width="2.2"
      marker-end={`url(#${defsId}-arrow)`}></line>
    <DiagramNode
      x={168}
      y={52}
      w={128}
      h={60}
      title="Cloudflare"
      subtitle="DNS · TLS · WAF"
      variant="blue"
      defsId={defsId}
    />
    <line
      x1="296"
      y1="82"
      x2="336"
      y2="82"
      stroke="#111"
      stroke-width="2.2"
      marker-end={`url(#${defsId}-arrow)`}></line>
    <DiagramNode
      x={336}
      y={44}
      w={220}
      h={76}
      title="香港 APISIX"
      subtitle="api.i2kai.com · admin.i2kai.com"
      variant="accent"
      badge="入口"
      defsId={defsId}
    />
    <line
      x1="556"
      y1="82"
      x2="596"
      y2="82"
      stroke="#111"
      stroke-width="2.2"
      marker-end={`url(#${defsId}-arrow)`}></line>

    <g filter={`url(#${defsId}-shadow)`}>
      <rect
        x={596}
        y={44}
        width={472}
        height={112}
        rx="12"
        fill="#fff0c2"
        stroke="#111"
        stroke-width="2"></rect>
      <text x={616} y={72} font-size="13" font-weight="700" fill="#111">香港运行时服务群</text>
      <text x={616} y={94} font-size="11" fill="#5d625f">
        gateway · app-router · public-api · admin-api · storage-api
      </text>
      <text x={616} y={114} font-size="11" fill="#5d625f">
        auth · payment · vip · voice · translation · channel · promotion · file …
      </text>
      <text x={616} y={134} font-size="11" fill="#5d625f">
        PostgreSQL · Redis · ETCD · files.i2kai.com（可独立落点）
      </text>
      <text x={616} y={148} font-size="10" font-weight="600" fill="#1f8f5f"
        >118.193.47.55 · 主写数据收敛香港侧</text
      >
    </g>

    <DiagramLane
      x={16}
      y={192}
      w={520}
      h={148}
      label="平台机（构建 · 注册 · 部署）"
      color="#e7e3db"
    />

    <DiagramNode
      x={32}
      y={224}
      w={140}
      h={60}
      title="平台机"
      subtitle="Gitea · Actions"
      variant="muted"
      defsId={defsId}
    />
    <line
      x1="172"
      y1="254"
      x2="212"
      y2="254"
      stroke="#111"
      stroke-width="2"
      stroke-dasharray="6 4"
      marker-end={`url(#${defsId}-arrow)`}></line>
    <text x="188" y="244" font-size="9" fill="#5d625f">deploy</text>
    <DiagramNode
      x={212}
      y={224}
      w={140}
      h={60}
      title="Registry"
      subtitle="镜像 · 制品"
      variant="muted"
      defsId={defsId}
    />
    <line
      x1="352"
      y1="254"
      x2="392"
      y2="254"
      stroke="#111"
      stroke-width="2"
      stroke-dasharray="6 4"
      marker-end={`url(#${defsId}-arrow)`}></line>
    <DiagramNode
      x={392}
      y={224}
      w={128}
      h={60}
      title="香港机"
      subtitle="拉取 · 滚动"
      variant="accent"
      defsId={defsId}
    />

    <DiagramLane x={552} y={192} w={532} h={148} label="开源协作面（与本站）" color="#dff4e6" />

    <DiagramNode
      x={568}
      y={224}
      w={160}
      h={60}
      title="GitHub Pages"
      subtitle="apps.open.i2kai.com"
      variant="default"
      defsId={defsId}
    />
    <DiagramNode
      x={752}
      y={224}
      w={160}
      h={60}
      title="Open 仓"
      subtitle="lys-apps-progress"
      variant="default"
      defsId={defsId}
    />
    <DiagramNode
      x={936}
      y={224}
      w={132}
      h={60}
      title="HUB 主仓"
      subtitle="标准 · 文档"
      variant="default"
      defsId={defsId}
    />
    <text x={568} y={310} font-size="11" fill="#5d625f"
      >sync-to-open.sh 同步进度与架构 · 出门协作读公开站</text
    >

    <DiagramLane x={16} y={360} w={1068} h={148} label="本地联调拓扑（开发者）" color="#f7f3ea" />

    <DiagramNode x={32} y={392} w={120} h={52} title="本地 App" subtitle="模拟器" defsId={defsId} />
    <DiagramNode
      x={168}
      y={392}
      w={120}
      h={52}
      title="natapp"
      subtitle="回调穿透"
      variant="muted"
      defsId={defsId}
    />
    <DiagramNode
      x={304}
      y={384}
      w={140}
      h={68}
      title="local APISIX"
      subtitle="18000 段"
      variant="accent"
      defsId={defsId}
    />
    <DiagramNode x={460} y={392} w={120} h={52} title="gateway" defsId={defsId} />
    <DiagramNode
      x={596}
      y={392}
      w={140}
      h={52}
      title="public-api"
      subtitle="55000 段"
      defsId={defsId}
    />
    <DiagramNode
      x={752}
      y={392}
      w={140}
      h={52}
      title="共享服务"
      subtitle="18000 段"
      variant="rpc"
      defsId={defsId}
    />
    <DiagramNode
      x={908}
      y={392}
      w={160}
      h={52}
      title="PostgreSQL"
      subtitle="Redis · ETCD"
      variant="muted"
      defsId={defsId}
    />

    {
      [
        [152, 418, 168, 418],
        [288, 418, 304, 418],
        [444, 418, 460, 418],
        [580, 418, 596, 418],
        [736, 418, 752, 418],
        [892, 418, 908, 418],
      ].map(([x1, y1, x2, y2]) => (
        <line
          x1={x1}
          y1={y1}
          x2={x2}
          y2={y2}
          stroke="#111"
          stroke-width="2"
          marker-end={`url(#${defsId}-arrow)`}
        />
      ))
    }

    <DiagramCallout
      x={16}
      y={468}
      w={1068}
      title="拓扑原则"
      tone="warn"
      defsId={defsId}
      lines={[
        '公网统一 APISIX 入口 · 平台机与运行面分离 · 旧国内机已退出主业务 · 新端口先登记 app-port-registry.json',
      ]}
    />
  </svg>
</ArchitectureDiagrams>
