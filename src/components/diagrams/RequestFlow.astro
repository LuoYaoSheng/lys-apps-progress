---
import ArchitectureDiagrams from '../ArchitectureDiagrams.astro';
---

<ArchitectureDiagrams
  id="diagram-request"
  title="图 2 · 用户侧端到端"
  caption="App 不直连 RPC。所有正式请求先进入 APISIX，经 gateway 分流到 public-api，再聚合平台微服务。"
>
  <svg viewBox="0 0 1100 420" role="img" aria-label="用户侧端到端请求架构图">
    <defs>
      <marker id="arr2" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill="#111"></path>
      </marker>
    </defs>
    <!-- 主链路 -->
    {
      [
        { x: 20, label: '用户', sub: 'App 终端' },
        { x: 130, label: '客户端', sub: 'Flutter/UniApp' },
        { x: 260, label: 'SDK', sub: 'hub_core' },
        { x: 370, label: 'APISIX', sub: 'api.i2kai.com', accent: true },
        { x: 500, label: 'gateway', sub: '协议/Token' },
        { x: 620, label: 'app-router', sub: '按 appId 路由' },
        { x: 760, label: 'public-api', sub: 'App HTTP 门面' },
      ].map((n, i, arr) => (
        <>
          <rect
            x={n.x}
            y="40"
            width="100"
            height="56"
            rx="8"
            fill={n.accent ? '#1f8f5f' : '#fffdf8'}
            stroke="#111"
            stroke-width="2"
          />
          <text
            x={n.x + 50}
            y="68"
            text-anchor="middle"
            font-size="13"
            font-weight="700"
            fill={n.accent ? '#fff' : '#111'}
          >
            {n.label}
          </text>
          <text
            x={n.x + 50}
            y="84"
            text-anchor="middle"
            font-size="10"
            fill={n.accent ? '#dff4e6' : '#5d625f'}
          >
            {n.sub}
          </text>
          {i < arr.length - 1 && (
            <line
              x1={n.x + 100}
              y1="68"
              x2={arr[i + 1].x}
              y2="68"
              stroke="#111"
              stroke-width="2"
              marker-end="url(#arr2)"
            />
          )}
        </>
      ))
    }
    <!-- RPC 下沉 -->
    <line x1="810" y1="96" x2="810" y2="140" stroke="#111" stroke-width="2" marker-end="url(#arr2)"
    ></line>
    <text x="820" y="128" font-size="10" fill="#5d625f">RPC 聚合</text>
    {
      [
        { x: 80, label: 'auth-rpc' },
        { x: 220, label: 'payment-rpc' },
        { x: 360, label: 'channel-rpc' },
        { x: 500, label: 'file-rpc' },
        { x: 640, label: 'voice-rpc' },
        { x: 780, label: 'translation-rpc' },
        { x: 920, label: 'vip-rpc' },
      ].map((n) => (
        <>
          <rect
            x={n.x}
            y="150"
            width="110"
            height="40"
            rx="6"
            fill="#e7e3db"
            stroke="#111"
            stroke-width="1.5"
          />
          <text
            x={n.x + 55}
            y="175"
            text-anchor="middle"
            font-size="11"
            font-weight="600"
            fill="#111"
          >
            {n.label}
          </text>
        </>
      ))
    }
    <!-- storage 旁路 -->
    <line
      x1="420"
      y1="96"
      x2="420"
      y2="240"
      stroke="#111"
      stroke-width="2"
      stroke-dasharray="5 4"
      marker-end="url(#arr2)"></line>
    <rect
      x="360"
      y="250"
      width="120"
      height="44"
      rx="8"
      fill="#ffe1dc"
      stroke="#111"
      stroke-width="2"></rect>
    <text x="420" y="272" text-anchor="middle" font-size="12" font-weight="700" fill="#111"
      >storage-api</text
    >
    <text x="420" y="286" text-anchor="middle" font-size="10" fill="#5d625f">/v1/storage/*</text>
    <line
      x1="420"
      y1="294"
      x2="555"
      y2="170"
      stroke="#111"
      stroke-width="1.5"
      stroke-dasharray="4 3"></line>

    <rect
      x="40"
      y="330"
      width="1020"
      height="68"
      rx="8"
      fill="#f7f3ea"
      stroke="#111"
      stroke-width="1.5"></rect>
    <text x="60" y="356" font-size="12" font-weight="700" fill="#111">关键约束</text>
    <text x="60" y="378" font-size="11" fill="#5d625f">
      ① App 不直连微服务 ② public-api 是门面不是事实源 ③ 账号/支付/文件主规则在平台 RPC
    </text>
  </svg>
</ArchitectureDiagrams>
