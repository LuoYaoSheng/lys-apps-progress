---
import ArchitectureDiagrams from '../ArchitectureDiagrams.astro';
import DiagramCallout from './primitives/DiagramCallout.astro';
import DiagramDefs from './primitives/DiagramDefs.astro';
import DiagramLane from './primitives/DiagramLane.astro';
import DiagramNode from './primitives/DiagramNode.astro';

const defsId = 'req';
const mainChain = [
  { x: 28, title: '用户', sub: 'App 终端', variant: 'default' as const },
  { x: 158, title: '客户端', sub: 'Flutter / UniApp / H5', variant: 'default' as const },
  { x: 288, title: 'SDK', sub: 'hub_core · 设备签名', variant: 'default' as const },
  { x: 418, title: 'APISIX', sub: 'api.i2kai.com', variant: 'accent' as const, badge: '入口' },
  { x: 548, title: 'gateway', sub: '协议 · Token · 聚合', variant: 'blue' as const },
  { x: 678, title: 'app-router', sub: '按 appId 路由', variant: 'blue' as const },
  { x: 808, title: 'public-api', sub: 'App HTTP 门面', variant: 'default' as const },
];

const rpcRow1 = ['auth-rpc', 'channel-rpc', 'payment-rpc', 'promotion-rpc', 'file-rpc', 'vip-rpc'];
const rpcRow2 = [
  'voice-rpc',
  'translation-rpc',
  'notification-rpc',
  'content-rpc',
  'legal-rpc',
  'feedback-rpc',
];
---

<ArchitectureDiagrams
  id="diagram-request"
  title="图 2 · 用户侧端到端"
  caption="HTTP 门面层与 RPC 领域层分离：public-api 编排调用，账号/支付/文件等主规则留在平台微服务。"
  highlights={['不直连 RPC', '门面 ≠ 事实源', 'storage 旁路']}
>
  <svg viewBox="0 0 1140 500" role="img" aria-label="用户侧端到端请求架构图">
    <DiagramDefs id={defsId} />
    <rect width="1140" height="500" fill={`url(#${defsId}-grid)`}></rect>

    <DiagramLane
      x={20}
      y={28}
      w={1100}
      h={118}
      label="HTTP 入口链路（App 正式请求）"
      color="#dcecff"
    />

    {
      mainChain.map((n, i, arr) => (
        <>
          <DiagramNode
            x={n.x}
            y={58}
            w={118}
            h={62}
            title={n.title}
            subtitle={n.sub}
            variant={n.variant}
            badge={n.badge}
            defsId={defsId}
          />
          {i < arr.length - 1 && (
            <line
              x1={n.x + 118}
              y1="89"
              x2={arr[i + 1].x}
              y2="89"
              stroke="#111"
              stroke-width="2.2"
              marker-end={`url(#${defsId}-arrow)`}
            />
          )}
        </>
      ))
    }

    <line
      x1="867"
      y1="120"
      x2="867"
      y2="168"
      stroke="#111"
      stroke-width="2.2"
      marker-end={`url(#${defsId}-arrow)`}></line>
    <text x="878" y="152" font-size="10" font-weight="600" fill="#5d625f">gRPC 聚合</text>

    <DiagramLane
      x={20}
      y={168}
      w={1100}
      h={148}
      label="平台 RPC 领域层（共享微服务 · 事实源）"
      color="#e7e3db"
    />

    {
      rpcRow1.map((label, i) => (
        <DiagramNode
          x={36 + i * 178}
          y={204}
          w={158}
          h={44}
          title={label}
          variant="rpc"
          defsId={defsId}
          rx={8}
        />
      ))
    }
    {
      rpcRow2.map((label, i) => (
        <DiagramNode
          x={36 + i * 178}
          y={258}
          w={158}
          h={44}
          title={label}
          variant="rpc"
          defsId={defsId}
          rx={8}
        />
      ))
    }

    <!-- payment → vip -->
    <path
      d="M 392 248 L 392 268 L 926 268 L 926 248"
      fill="none"
      stroke="#1f8f5f"
      stroke-width="1.8"
      stroke-dasharray="5 4"
      marker-end={`url(#${defsId}-arrow-green)`}></path>
    <text x="640" y="284" text-anchor="middle" font-size="10" font-weight="600" fill="#1f8f5f">
      支付履约链 payment-rpc → vip-rpc
    </text>

    <!-- storage 旁路 -->
    <DiagramLane
      x={20}
      y={332}
      w={360}
      h={108}
      label="文件旁路（不经 public-api）"
      color="#ffe1dc"
    />
    <line
      x1="477"
      y1="120"
      x2="477"
      y2="360"
      stroke="#f25f4c"
      stroke-width="2"
      stroke-dasharray="6 5"
      marker-end={`url(#${defsId}-arrow)`}></line>
    <DiagramNode
      x={48}
      y={368}
      w={140}
      h={52}
      title="storage-api"
      subtitle="/v1/storage/*"
      variant="storage"
      defsId={defsId}
    />
    <line
      x1="188"
      y1="394"
      x2="280"
      y2="248"
      stroke="#111"
      stroke-width="1.5"
      stroke-dasharray="4 3"></line>
    <text x="210" y="320" font-size="10" fill="#5d625f">→ file-rpc</text>

    <DiagramCallout
      x={400}
      y={332}
      w={720}
      title="关键约束"
      tone="warn"
      defsId={defsId}
      lines={[
        '① App 正式客户端优先走 /app/{appId}/v1/*，业务不长期挂旧公共路径',
        '② 支付回调、推广短链、广告 postback 走 /v1/* 或 /s/*，不走 App 私有路由',
        '③ gateway / public-api / admin-api 都是门面；配置与订单事实在 RPC + PostgreSQL',
      ]}
    />
  </svg>
</ArchitectureDiagrams>
