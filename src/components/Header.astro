---
import { navItems, siteMeta } from '../data/site';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label={siteMeta.siteName}>
      <span class="brand-mark">50</span>
      <span class="brand-text">Apps Progress</span>
    </a>
    <nav class="nav-links" aria-label="主导航">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</header>
