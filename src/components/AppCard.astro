---
import { categoryLabels, statusMeta } from '../data/site';
import type { AppProgress } from '../data/apps';

interface Props {
  app: AppProgress;
}

const { app } = Astro.props;
const status = statusMeta[app.status];
---

<article class="app-card" data-status={app.status} data-category={app.category}>
  <a href={`/apps/${app.slug}`} class="app-card-link" aria-label={`查看 ${app.name}`}>
    <div class="app-card-top">
      {
        app.icon ? (
          <img class="app-icon" src={app.icon} alt="" loading="lazy" />
        ) : (
          <span class="app-icon app-icon-fallback">{app.name.slice(0, 1)}</span>
        )
      }
      <span class={`status-badge tone-${status.tone}`}>{status.label}</span>
    </div>
    <h3>{app.name}</h3>
    <p>{app.tagline}</p>
    <div class="progress-track" aria-label={`${app.name} 完成度 ${app.progress}%`}>
      <span style={`width: ${app.progress}%`}></span>
    </div>
    <div class="app-card-meta">
      <span>{categoryLabels[app.category]}</span>
      <span>{app.month}</span>
    </div>
  </a>
</article>
