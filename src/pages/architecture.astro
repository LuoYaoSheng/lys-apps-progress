---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdminFlow from '../components/diagrams/AdminFlow.astro';
import AppLifecycle from '../components/diagrams/AppLifecycle.astro';
import EcosystemOverview from '../components/diagrams/EcosystemOverview.astro';
import ProductionTopo from '../components/diagrams/ProductionTopo.astro';
import RequestFlow from '../components/diagrams/RequestFlow.astro';
import RouteSplit from '../components/diagrams/RouteSplit.astro';
import {
  architectureMeta,
  platformModules,
  sharedCapabilities,
  statusLabels,
} from '../data/architecture';
import { apps, getProgressStats } from '../data/apps';
import { target } from '../data/site';

const stats = getProgressStats();
const completion = Math.round((stats.released / target.total) * 100);
---

<BaseLayout
  title="整体架构"
  description="HUB 多 App 生态架构速览：平台分层、请求链路、模块进度与交付对照。供团队外出协作同步。"
>
  <main>
    <section class="page-title">
      <div class="container">
        <p class="section-kicker">TEAM SYNC · 更新 {architectureMeta.updatedAt}</p>
        <h1>{architectureMeta.title}</h1>
        <p>{architectureMeta.summary}</p>
        <div class="section-actions" style="margin-top: 20px">
          <a class="button-primary" href="/apps">应用目录</a>
          <a class="button-secondary" href="/timeline">时间线</a>
        </div>
      </div>
    </section>

    <!-- 进度快照：出门一眼看交付 -->
    <section class="container arch-snapshot">
      <div class="snapshot-grid">
        <div class="snapshot-card snapshot-highlight">
          <span class="snapshot-label">年度进度</span>
          <strong class="snapshot-value">{stats.released}<span>/ {target.total}</span></strong>
          <div class="progress-track" aria-label={`完成 ${completion}%`}>
            <span style={`width: ${completion}%`}></span>
          </div>
          <span class="snapshot-note">{completion}% · 已发布 {stats.released} 个公开作品</span>
        </div>
        <div class="snapshot-card">
          <span class="snapshot-label">开发中</span>
          <strong class="snapshot-value">{stats.active}</strong>
          <span class="snapshot-note">building / testing / design</span>
        </div>
        <div class="snapshot-card">
          <span class="snapshot-label">开源项目</span>
          <strong class="snapshot-value">{stats.openSource}</strong>
          <span class="snapshot-note">见 open.i2kai.com</span>
        </div>
        <div class="snapshot-card">
          <span class="snapshot-label">APP + 小程序</span>
          <strong class="snapshot-value">{stats.appCount + stats.miniPrograms}</strong>
          <span class="snapshot-note">移动交付条目</span>
        </div>
      </div>
    </section>

    <!-- 架构图（重点） -->
    <section class="container arch-diagrams-section">
      <div class="section-header" style="margin-bottom: 20px">
        <div>
          <p class="section-kicker">ARCHITECTURE MAPS</p>
          <h2>架构图</h2>
          <p>与 HUB 主仓 <code>docs/项目/01_系统架构.md</code> 对齐，出门协作可直接看图说话。</p>
        </div>
      </div>
      <nav class="diagram-toc" aria-label="架构图目录">
        <a href="#diagram-ecosystem">① 生态总览</a>
        <a href="#diagram-request">② 端到端</a>
        <a href="#diagram-routes">③ 路由分流</a>
        <a href="#diagram-admin">④ Admin</a>
        <a href="#diagram-lifecycle">⑤ 启动支付</a>
        <a href="#diagram-production">⑥ 生产拓扑</a>
      </nav>
      <div class="arch-diagrams-grid">
        <EcosystemOverview />
        <RequestFlow />
        <RouteSplit />
        <AdminFlow />
        <AppLifecycle />
        <ProductionTopo />
      </div>
    </section>

    <section class="container about-stack">
      <!-- 平台模块进度 -->
      <article class="detail-panel">
        <p class="section-kicker">PLATFORM</p>
        <h2>平台模块完成度</h2>
        <table class="arch-table">
          <thead>
            <tr><th>模块</th><th>状态</th><th>说明</th></tr>
          </thead>
          <tbody>
            {
              platformModules.map((m) => (
                <tr>
                  <td>
                    <strong>{m.name}</strong>
                  </td>
                  <td>
                    <span class={`status-pill status-${m.status}`}>{statusLabels[m.status]}</span>
                  </td>
                  <td>{m.note}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </article>

      <!-- 共享能力 -->
      <article class="detail-panel">
        <p class="section-kicker">CAPABILITIES</p>
        <h2>共享能力域</h2>
        <p>多个 App 复用平台能力，避免每个产品重复做账号、支付、语音等基础模块。</p>
        <div class="about-cards">
          {
            sharedCapabilities.map((cap) => (
              <div class="about-card">
                <h3>{cap.name}</h3>
                <p>{cap.apps}</p>
              </div>
            ))
          }
        </div>
      </article>

      <article class="detail-panel">
        <p class="section-kicker">APPS</p>
        <h2>应用与进度</h2>
        <p>
          每个 App 干什么、项目后缀与排期，见应用目录（{apps.length} 条 50 Builds 跟踪 + 全量 HUB 清单）。
        </p>
        <div class="section-actions" style="margin-top:16px">
          <a class="button-primary" href="/apps">打开应用目录</a>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>
