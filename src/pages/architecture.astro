---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdminFlow from '../components/diagrams/AdminFlow.astro';
import AppLifecycle from '../components/diagrams/AppLifecycle.astro';
import EcosystemOverview from '../components/diagrams/EcosystemOverview.astro';
import ProductionTopo from '../components/diagrams/ProductionTopo.astro';
import RequestFlow from '../components/diagrams/RequestFlow.astro';
import RouteSplit from '../components/diagrams/RouteSplit.astro';
import {
  architectureMeta,
  keyConstraints,
  platformModules,
  referenceApps,
  sharedCapabilities,
  statusLabels,
} from '../data/architecture';
import {
  mainFlows,
  microserviceMeta,
  platformServices,
  serviceKindLabels,
  serviceLayerLabels,
  serviceLayerOrder,
} from '../data/microservices';
import { apps, getProgressStats } from '../data/apps';
import { target } from '../data/site';

const stats = getProgressStats();
const completion = Math.round((stats.released / target.total) * 100);
---

<BaseLayout
  title="整体架构"
  description="HUB 多 App 生态架构速览：平台分层、请求链路、模块进度与交付对照。供团队外出协作同步。"
>
  <main>
    <section class="page-title">
      <div class="container">
        <p class="section-kicker">TEAM SYNC · 更新 {architectureMeta.updatedAt}</p>
        <h1>{architectureMeta.title}</h1>
        <p>{architectureMeta.summary}</p>
        <div class="arch-rule-banner">
          <span class="arch-rule-label">固定认知</span>
          <strong>所有正式请求都先进入 APISIX</strong>
        </div>
        <div class="section-actions" style="margin-top: 20px">
          <a class="button-primary" href="/apps">应用目录</a>
          <a class="button-secondary" href="/timeline">时间线</a>
        </div>
      </div>
    </section>

    <!-- 进度快照：出门一眼看交付 -->
    <section class="container arch-snapshot">
      <div class="snapshot-grid">
        <div class="snapshot-card snapshot-highlight">
          <span class="snapshot-label">年度进度</span>
          <strong class="snapshot-value">{stats.released}<span>/ {target.total}</span></strong>
          <div class="progress-track" aria-label={`完成 ${completion}%`}>
            <span style={`width: ${completion}%`}></span>
          </div>
          <span class="snapshot-note">{completion}% · 已发布 {stats.released} 个公开作品</span>
        </div>
        <div class="snapshot-card">
          <span class="snapshot-label">开发中</span>
          <strong class="snapshot-value">{stats.active}</strong>
          <span class="snapshot-note">building / testing / design</span>
        </div>
        <div class="snapshot-card">
          <span class="snapshot-label">开源项目</span>
          <strong class="snapshot-value">{stats.openSource}</strong>
          <span class="snapshot-note">见 open.i2kai.com</span>
        </div>
        <div class="snapshot-card">
          <span class="snapshot-label">APP + 小程序</span>
          <strong class="snapshot-value">{stats.appCount + stats.miniPrograms}</strong>
          <span class="snapshot-note">移动交付条目</span>
        </div>
      </div>
    </section>

    <!-- 架构图（重点） -->
    <section class="container arch-diagrams-section">
      <div class="section-header" style="margin-bottom: 20px">
        <div>
          <p class="section-kicker">ARCHITECTURE MAPS</p>
          <h2>架构图</h2>
          <p>与 HUB 主仓 <code>docs/项目/01_系统架构.md</code> 对齐，出门协作可直接看图说话。</p>
        </div>
      </div>
      <nav class="diagram-toc" aria-label="架构图目录">
        <a href="#diagram-ecosystem">① 生态总览</a>
        <a href="#diagram-request">② 端到端</a>
        <a href="#diagram-routes">③ 路由分流</a>
        <a href="#diagram-admin">④ Admin</a>
        <a href="#diagram-lifecycle">⑤ 启动支付</a>
        <a href="#diagram-production">⑥ 生产拓扑</a>
        <a href="#microservices">⑦ 微服务索引</a>
        <a href="#main-flows">⑧ 主流程</a>
      </nav>
      <div class="arch-diagrams-grid">
        <EcosystemOverview />
        <RequestFlow />
        <RouteSplit />
        <AdminFlow />
        <AppLifecycle />
        <ProductionTopo />
      </div>
    </section>

    <section class="container arch-microservices" id="microservices">
      <div class="section-header">
        <div>
          <p class="section-kicker">MICROSERVICES</p>
          <h2>微服务索引</h2>
          <p>
            摘要自 HUB 主仓 <code>{microserviceMeta.source}</code>（{
              microserviceMeta.updatedAt
            }）。共 {platformServices.length} 个平台组件与服务。
          </p>
          <p class="micro-topology">
            <strong>拓扑：</strong>{microserviceMeta.topology}
          </p>
        </div>
      </div>

      <div class="micro-layer-legend">
        {
          serviceLayerOrder.map((layer) => (
            <span class={`layer-pill layer-pill--${layer}`}>{serviceLayerLabels[layer]}</span>
          ))
        }
      </div>

      <div class="micro-filters">
        <input
          type="search"
          id="microSearch"
          class="micro-search"
          placeholder="搜索服务名、路径、职责…"
          aria-label="搜索微服务"
        />
        <div class="micro-filter-pills" role="group" aria-label="按层次筛选">
          <button type="button" class="filter-pill is-active" data-micro-layer="all">全部</button>
          {
            serviceLayerOrder.map((layer) => (
              <button type="button" class="filter-pill" data-micro-layer={layer}>
                {serviceLayerLabels[layer]}
              </button>
            ))
          }
        </div>
      </div>

      <div class="micro-table-wrap">
        <table class="arch-table micro-table">
          <thead>
            <tr>
              <th>服务</th>
              <th>层次</th>
              <th>形态</th>
              <th>路径 / 域</th>
              <th>主责</th>
            </tr>
          </thead>
          <tbody>
            {
              platformServices.map((svc) => (
                <tr
                  class="micro-row"
                  data-micro-layer={svc.layer}
                  data-micro-search={`${svc.name} ${svc.paths} ${svc.responsibility} ${svc.note || ''}`}
                >
                  <td>
                    <strong>{svc.name}</strong>
                    {svc.note && <span class="micro-note">{svc.note}</span>}
                  </td>
                  <td>
                    <span class={`layer-pill layer-pill--${svc.layer}`}>
                      {serviceLayerLabels[svc.layer]}
                    </span>
                  </td>
                  <td>
                    <code class="kind-code">{serviceKindLabels[svc.kind]}</code>
                  </td>
                  <td>
                    <code class="path-code">{svc.paths}</code>
                  </td>
                  <td>{svc.responsibility}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="notice" id="microEmpty" hidden>没有匹配的服务。</p>
    </section>

    <section class="container arch-flows" id="main-flows">
      <div class="section-header">
        <div>
          <p class="section-kicker">MAIN FLOWS</p>
          <h2>四条主流程（代码冻结版）</h2>
          <p>与微服务索引 §2.6 对齐，便于排查「配置写了为何没生效」「上传/支付/发码走哪条链」。</p>
        </div>
      </div>
      <div class="flow-cards">
        {
          mainFlows.map((flow, i) => (
            <article class="flow-card" id={`flow-${flow.id}`}>
              <header class="flow-card-head">
                <span class="flow-index">{String(i + 1).padStart(2, '0')}</span>
                <div>
                  <h3>{flow.title}</h3>
                  <p>{flow.summary}</p>
                </div>
              </header>
              <ol class="flow-steps">
                {flow.steps.map((step) => (
                  <li>{step}</li>
                ))}
              </ol>
              <footer class="flow-related">
                <span>涉及：</span>
                {flow.relatedServices.map((name) => (
                  <code>{name}</code>
                ))}
              </footer>
            </article>
          ))
        }
      </div>
    </section>

    <section class="container arch-constraints">
      <div class="section-header">
        <div>
          <p class="section-kicker">CONSTRAINTS</p>
          <h2>关键约束</h2>
          <p>与主仓架构文档一致，协作时优先对齐以下六条。</p>
        </div>
      </div>
      <div class="constraint-grid">
        {
          keyConstraints.map((c, i) => (
            <article class="constraint-card">
              <span class="constraint-index">{String(i + 1).padStart(2, '0')}</span>
              <h3>{c.title}</h3>
              <p>{c.desc}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="container about-stack">
      <!-- 平台模块进度 -->
      <article class="detail-panel">
        <p class="section-kicker">PLATFORM</p>
        <h2>平台模块完成度</h2>
        <table class="arch-table">
          <thead>
            <tr><th>模块</th><th>状态</th><th>说明</th></tr>
          </thead>
          <tbody>
            {
              platformModules.map((m) => (
                <tr>
                  <td>
                    <strong>{m.name}</strong>
                  </td>
                  <td>
                    <span class={`status-pill status-${m.status}`}>{statusLabels[m.status]}</span>
                  </td>
                  <td>{m.note}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </article>

      <!-- 共享能力 -->
      <article class="detail-panel">
        <p class="section-kicker">CAPABILITIES</p>
        <h2>共享能力域</h2>
        <p>多个 App 复用平台能力，避免每个产品重复做账号、支付、语音等基础模块。</p>
        <div class="about-cards">
          {
            sharedCapabilities.map((cap) => (
              <div class="about-card">
                <h3>{cap.name}</h3>
                <p>{cap.apps}</p>
              </div>
            ))
          }
        </div>
      </article>

      <article class="detail-panel">
        <p class="section-kicker">REFERENCE APPS</p>
        <h2>四 App 样板</h2>
        <p>平台参照的代表性应用，覆盖 UniApp / Flutter 与不同能力组合。</p>
        <div class="ref-app-grid">
          {
            referenceApps.map((app) => (
              <div class="ref-app-card">
                <h3>{app.name}</h3>
                <code>{app.appKey}</code>
                <p>{app.purpose}</p>
                <span class="ref-tech">{app.tech}</span>
                {app.slug ? (
                  <a
                    class="button-secondary"
                    href={`/apps/${app.slug}`}
                    style="margin-top:12px;display:inline-block"
                  >
                    看公开进度 →
                  </a>
                ) : (
                  <span class="ref-note">业务样板 · 见应用目录同类条目</span>
                )}
              </div>
            ))
          }
        </div>
      </article>

      <article class="detail-panel">
        <p class="section-kicker">APPS</p>
        <h2>应用与进度</h2>
        <p>
          每个 App 干什么、项目后缀与排期，见应用目录（{apps.length} 条 50 Builds 跟踪 + 全量 HUB 清单）。
        </p>
        <div class="section-actions" style="margin-top:16px">
          <a class="button-primary" href="/apps">打开应用目录</a>
        </div>
      </article>
    </section>
  </main>

  <div class="diagram-lightbox" data-diagram-lightbox hidden>
    <div class="diagram-lightbox-backdrop" data-diagram-lightbox-close></div>
    <div class="diagram-lightbox-panel" role="dialog" aria-modal="true" aria-label="架构图全屏">
      <header class="diagram-lightbox-header">
        <strong data-diagram-lightbox-title></strong>
        <div class="diagram-lightbox-tools">
          <button type="button" class="diagram-tool" data-lightbox-action="zoom-out">−</button>
          <span class="diagram-scale" data-lightbox-scale>100%</span>
          <button type="button" class="diagram-tool" data-lightbox-action="zoom-in">+</button>
          <button type="button" class="diagram-tool" data-lightbox-action="reset">重置</button>
          <button type="button" class="diagram-tool" data-lightbox-action="close">关闭</button>
        </div>
      </header>
      <div class="diagram-lightbox-canvas" data-lightbox-canvas>
        <div class="arch-diagram-stage" data-lightbox-stage></div>
      </div>
    </div>
  </div>

  <script>
    type ZoomState = { scale: number; x: number; y: number };

    function clamp(n: number, min: number, max: number) {
      return Math.min(max, Math.max(min, n));
    }

    function applyTransform(stage: HTMLElement, state: ZoomState) {
      stage.style.transform = `translate(${state.x}px, ${state.y}px) scale(${state.scale})`;
    }

    function formatScale(scale: number) {
      return `${Math.round(scale * 100)}%`;
    }

    function createZoomController(
      canvas: HTMLElement,
      stage: HTMLElement,
      scaleEl: HTMLElement | null,
      initialScale = 1,
    ) {
      const state: ZoomState = { scale: initialScale, x: 0, y: 0 };
      let dragging = false;
      let lastX = 0;
      let lastY = 0;

      const render = () => {
        applyTransform(stage, state);
        if (scaleEl) scaleEl.textContent = formatScale(state.scale);
      };

      const zoomBy = (delta: number) => {
        state.scale = clamp(state.scale + delta, 0.5, 3);
        render();
      };

      const reset = () => {
        state.scale = initialScale;
        state.x = 0;
        state.y = 0;
        render();
      };

      canvas.addEventListener(
        'wheel',
        (event) => {
          event.preventDefault();
          zoomBy(event.deltaY < 0 ? 0.12 : -0.12);
        },
        { passive: false },
      );

      canvas.addEventListener('pointerdown', (event) => {
        if ((event.target as HTMLElement).closest('[data-diagram-action]')) return;
        dragging = true;
        lastX = event.clientX;
        lastY = event.clientY;
        canvas.setPointerCapture(event.pointerId);
        canvas.classList.add('is-panning');
      });

      canvas.addEventListener('pointermove', (event) => {
        if (!dragging) return;
        state.x += event.clientX - lastX;
        state.y += event.clientY - lastY;
        lastX = event.clientX;
        lastY = event.clientY;
        render();
      });

      const stopDrag = (event: PointerEvent) => {
        if (!dragging) return;
        dragging = false;
        canvas.classList.remove('is-panning');
        canvas.releasePointerCapture(event.pointerId);
      };

      canvas.addEventListener('pointerup', stopDrag);
      canvas.addEventListener('pointercancel', stopDrag);
      canvas.addEventListener('dblclick', reset);

      render();
      return { zoomBy, reset, getState: () => state, render };
    }

    const figures = document.querySelectorAll('[data-diagram-figure]');
    const lightbox = document.querySelector('[data-diagram-lightbox]') as HTMLElement | null;
    const lightboxTitle = document.querySelector('[data-diagram-lightbox-title]');
    const lightboxStage = document.querySelector('[data-lightbox-stage]') as HTMLElement | null;
    const lightboxCanvas = document.querySelector('[data-lightbox-canvas]') as HTMLElement | null;
    const lightboxScale = document.querySelector('[data-lightbox-scale]') as HTMLElement | null;
    let lightboxZoom: ReturnType<typeof createZoomController> | null = null;

    figures.forEach((figure) => {
      const canvas = figure.querySelector('[data-diagram-canvas]') as HTMLElement | null;
      const stage = figure.querySelector('[data-diagram-stage]') as HTMLElement | null;
      const scaleEl = figure.querySelector('[data-diagram-scale]') as HTMLElement | null;
      if (!canvas || !stage) return;

      const zoom = createZoomController(canvas, stage, scaleEl);

      figure.querySelectorAll('[data-diagram-action]').forEach((button) => {
        button.addEventListener('click', () => {
          const action = button.getAttribute('data-diagram-action');
          if (action === 'zoom-in') zoom.zoomBy(0.15);
          if (action === 'zoom-out') zoom.zoomBy(-0.15);
          if (action === 'reset') zoom.reset();
          if (action === 'expand' && lightbox && lightboxStage && lightboxCanvas) {
            const title = figure.getAttribute('data-diagram-title') || '架构图';
            if (lightboxTitle) lightboxTitle.textContent = title;
            lightboxStage.innerHTML = stage.innerHTML;
            lightbox.hidden = false;
            document.body.classList.add('diagram-lightbox-open');
            lightboxZoom = createZoomController(lightboxCanvas, lightboxStage, lightboxScale, 1);
          }
        });
      });
    });

    const closeLightbox = () => {
      if (!lightbox) return;
      lightbox.hidden = true;
      if (lightboxStage) lightboxStage.innerHTML = '';
      document.body.classList.remove('diagram-lightbox-open');
      lightboxZoom = null;
    };

    document
      .querySelectorAll('[data-lightbox-action], [data-diagram-lightbox-close]')
      .forEach((el) => {
        el.addEventListener('click', () => {
          const action = el.getAttribute('data-lightbox-action');
          if (action === 'close' || el.hasAttribute('data-diagram-lightbox-close')) {
            closeLightbox();
            return;
          }
          if (!lightboxZoom) return;
          if (action === 'zoom-in') lightboxZoom.zoomBy(0.15);
          if (action === 'zoom-out') lightboxZoom.zoomBy(-0.15);
          if (action === 'reset') lightboxZoom.reset();
        });
      });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeLightbox();
    });

    const microSearch = document.getElementById('microSearch') as HTMLInputElement | null;
    const microRows = document.querySelectorAll('.micro-row');
    const microEmpty = document.getElementById('microEmpty');
    const microPills = document.querySelectorAll('.micro-filter-pills [data-micro-layer]');
    let microLayer = 'all';

    function applyMicroFilters() {
      const q = (microSearch?.value || '').trim().toLowerCase();
      let visible = 0;
      microRows.forEach((row) => {
        const layer = row.getAttribute('data-micro-layer') || '';
        const text = (row.getAttribute('data-micro-search') || '').toLowerCase();
        const layerOk = microLayer === 'all' || layer === microLayer;
        const searchOk = !q || text.includes(q);
        const show = layerOk && searchOk;
        row.toggleAttribute('hidden', !show);
        if (show) visible += 1;
      });
      if (microEmpty) microEmpty.hidden = visible !== 0;
    }

    microSearch?.addEventListener('input', applyMicroFilters);
    microPills.forEach((pill) => {
      pill.addEventListener('click', () => {
        microLayer = pill.getAttribute('data-micro-layer') || 'all';
        microPills.forEach((p) => p.classList.toggle('is-active', p === pill));
        applyMicroFilters();
      });
    });
  </script>
</BaseLayout>
