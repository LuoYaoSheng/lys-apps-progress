---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCatalogStats, catalog } from '../data/hub-catalog';
import { deliveryLabels, statusMeta } from '../data/site';

const { total, released, active, nextUp } = getCatalogStats();
---

<BaseLayout
  title="应用目录"
  description="HUB 全部应用一览：图标、名称、简介、项目后缀与交付进度，便于团队排期。"
>
  <main>
    <section class="page-title">
      <div class="container">
        <p class="section-kicker">APP CATALOG · {total} 个应用</p>
        <h1>应用目录</h1>
        <p>
          每个 App 干什么、项目目录后缀、当前进度。默认按「接下来该做哪个」排序。已发布 {released}
          个，进行中 {active} 个。
        </p>
      </div>
    </section>

    {
      nextUp.length > 0 && (
        <section class="container catalog-next">
          <p class="section-kicker">NEXT UP</p>
          <h2>建议优先推进</h2>
          <div class="catalog-next-row">
            {nextUp.map((app) => {
              const status = statusMeta[app.status];
              const fallback = app.name.slice(0, 1);
              const href = app.hasDetail && app.detailSlug ? `/apps/${app.detailSlug}` : null;
              const chipContent = (
                <>
                  {app.icon ? (
                    <img src={app.icon} alt="" width="28" height="28" />
                  ) : (
                    <span class="catalog-icon-fallback sm">{fallback}</span>
                  )}
                  <span>
                    <strong>{app.name}</strong>
                    <em>
                      {status.label} · {app.progress}%
                    </em>
                  </span>
                  <code>{app.projectKey}</code>
                </>
              );
              return href ? (
                <a href={href} class="catalog-next-chip">
                  {chipContent}
                </a>
              ) : (
                <div class="catalog-next-chip">{chipContent}</div>
              );
            })}
          </div>
        </section>
      )
    }

    <section class="container catalog-section">
      <div class="catalog-toolbar">
        <input
          type="search"
          id="catalogSearch"
          class="catalog-search"
          placeholder="搜索应用名、简介或项目后缀…"
          autocomplete="off"
        />
        <div class="filters" aria-label="状态筛选">
          <button class="filter-pill is-active" data-status="all">全部</button>
          {
            Object.entries(statusMeta).map(([key, item]) => (
              <button class="filter-pill" data-status={key}>
                {item.label}
              </button>
            ))
          }
        </div>
        <div class="filters" aria-label="分类筛选">
          <button class="filter-pill is-active" data-category="all">全部分类</button>
          {
            [...new Set(catalog.map((item) => item.category))].map((key) => (
              <button class="filter-pill" data-category={key}>
                {catalog.find((item) => item.category === key)?.categoryLabel}
              </button>
            ))
          }
        </div>
      </div>

      <div class="catalog-table-wrap">
        <table class="catalog-table" id="catalogTable">
          <thead>
            <tr>
              <th class="col-icon"></th>
              <th>应用名</th>
              <th>简介</th>
              <th>项目</th>
              <th>分类</th>
              <th>状态</th>
              <th>进度</th>
            </tr>
          </thead>
          <tbody>
            {
              catalog.map((app) => {
                const status = statusMeta[app.status];
                const fallback = app.name.slice(0, 1);
                const detailHref =
                  app.hasDetail && app.detailSlug ? `/apps/${app.detailSlug}` : null;
                return (
                  <tr
                    class="catalog-row"
                    data-status={app.status}
                    data-category={app.category}
                    data-search={`${app.name} ${app.description} ${app.projectKey} ${app.categoryLabel} ${deliveryLabels[app.delivery]}`}
                  >
                    <td class="col-icon">
                      {detailHref ? (
                        <a href={detailHref} class="catalog-icon-link">
                          {app.icon ? (
                            <img
                              src={app.icon}
                              alt=""
                              class="catalog-icon"
                              loading="lazy"
                              onerror="this.style.display='none';this.nextElementSibling.style.display='inline-grid'"
                            />
                          ) : null}
                          <span
                            class="catalog-icon-fallback"
                            style={app.icon ? 'display:none' : undefined}
                          >
                            {fallback}
                          </span>
                        </a>
                      ) : (
                        <span class="catalog-icon-link">
                          {app.icon ? (
                            <img src={app.icon} alt="" class="catalog-icon" loading="lazy" />
                          ) : (
                            <span class="catalog-icon-fallback">{fallback}</span>
                          )}
                        </span>
                      )}
                    </td>
                    <td class="col-name">
                      {detailHref ? (
                        <a href={detailHref}>
                          <strong>{app.name}</strong>
                          <span>{deliveryLabels[app.delivery]}</span>
                        </a>
                      ) : (
                        <div>
                          <strong>{app.name}</strong>
                          <span>{deliveryLabels[app.delivery]}</span>
                        </div>
                      )}
                    </td>
                    <td class="col-summary">{app.description}</td>
                    <td class="col-project">
                      <code title={`apps/${app.projectKey}`}>{app.projectKey}</code>
                    </td>
                    <td class="col-type">{app.categoryLabel}</td>
                    <td class="col-status">
                      <span class={`status-badge tone-${status.tone}`}>{status.label}</span>
                    </td>
                    <td class="col-progress">
                      <div class="progress-track compact">
                        <span style={`width: ${app.progress}%`} />
                      </div>
                      <span class="progress-pct">{app.progress}%</span>
                    </td>
                  </tr>
                );
              })
            }
          </tbody>
        </table>
      </div>
      <p class="notice" id="catalogEmpty" hidden>没有匹配的应用。</p>
      <p class="catalog-footnote">
        共 {total} 个应用，数据来自 HUB 应用目录。「项目」为 <code>apps/</code> 目录后缀；{released}
        个已纳入 50 Builds 进度跟踪，其余默认「想法池」待排期。
      </p>
    </section>
  </main>

  <script>
    const search = document.getElementById('catalogSearch');
    const rows = document.querySelectorAll('.catalog-row');
    const empty = document.getElementById('catalogEmpty');
    const statusPills = document.querySelectorAll('[data-status]');
    const categoryPills = document.querySelectorAll('[data-category]');
    let statusFilter = 'all';
    let categoryFilter = 'all';

    function applyCatalogFilters() {
      const q = ((search as HTMLInputElement | null)?.value || '').trim().toLowerCase();
      let visible = 0;
      rows.forEach((row) => {
        const status = row.getAttribute('data-status') || '';
        const category = row.getAttribute('data-category') || '';
        const text = (row.getAttribute('data-search') || '').toLowerCase();
        const statusOk = statusFilter === 'all' || status === statusFilter;
        const categoryOk = categoryFilter === 'all' || category === categoryFilter;
        const searchOk = !q || text.includes(q);
        const show = statusOk && categoryOk && searchOk;
        row.toggleAttribute('hidden', !show);
        if (show) visible += 1;
      });
      if (empty) empty.hidden = visible !== 0;
    }

    search?.addEventListener('input', applyCatalogFilters);
    statusPills.forEach((pill) => {
      pill.addEventListener('click', () => {
        statusFilter = pill.getAttribute('data-status') || 'all';
        statusPills.forEach((p) => {
          if (p.hasAttribute('data-status')) {
            p.classList.toggle('is-active', p === pill);
          }
        });
        applyCatalogFilters();
      });
    });
    categoryPills.forEach((pill) => {
      pill.addEventListener('click', () => {
        categoryFilter = pill.getAttribute('data-category') || 'all';
        categoryPills.forEach((p) => {
          if (p.hasAttribute('data-category')) {
            p.classList.toggle('is-active', p === pill);
          }
        });
        applyCatalogFilters();
      });
    });
  </script>
</BaseLayout>
